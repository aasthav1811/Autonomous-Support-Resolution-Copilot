# LLM provider: "groq" (hosted, free tier — default), "anthropic" (Claude API),
# or "ollama" (local, free)
LLM_PROVIDER=groq

# Required when LLM_PROVIDER=groq — free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here
# Optional: override the Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# Only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Only used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Browser origins allowed to call the API (comma-separated).
# Add your deployed frontend URL here, e.g. https://my-app.vercel.app
CORS_ORIGINS=http://localhost:3000
